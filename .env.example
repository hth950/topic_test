# Copy this file to .env and fill secrets locally.

# Required for GPT OAuth OCR and GPT repair.
DOGOK_PROXY_API_KEY=
GPT_OAUTH_BASE_URL=http://192.168.0.16:31835

# Required for GPT image OCR. The dogok proxy must be able to fetch crop images
# from this app over LAN. Update the IP if your Mac's LAN IP changes.
PUBLIC_BASE_URL=http://192.168.0.127:8767

# Chandra OCR defaults. These worked in local connectivity checks.
VLM_PRIMARY_BASE_URL=http://classday.iptime.org:8979/v1
VLM_FALLBACK_BASE_URL=http://210.115.224.151:31882/v1
VLM_MODEL_ID=chandra
VLLM_API_KEY=
